---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Footer from '../components/Footer.astro';

const navLinks = [
  { label: 'About', href: '#about' },
  { label: 'Projects', href: '#projects' },
  { label: 'Contact', href: '#contact' },
];

const projects = [
  {
    title: 'PixArt',
    description: 'Pixel art editor built with Java and JavaFX, including mini-games and custom drawing tools.',
    tags: ['Java', 'JavaFX', 'Graphics'],
    link: 'https://github.com/LoCh3f/OOP22-pixArt-gen',
  },
  {
    title: 'AgroNET',
    description: 'Social network platform for agriculture professionals developed with HTML, CSS, JS, PHP and SQL.',
    tags: ['PHP', 'SQL', 'Web'],
    link: 'https://github.com/Fre0Grella/AgroNET',
  },
  {
    title: 'ScoutKT',
    description: 'Real-time crypto market tracking app made in Kotlin with Jetpack Compose.',
    tags: ['Kotlin', 'Android', 'Compose'],
    link: 'https://github.com/LoCh3f/ScoutKT',
  },
  {
    title: 'Orbital',
    description: 'Microservices platform that aggregates real-time cryptocurrency market data and financial news, with RESTful APIs, Docker-based deployment, and monitoring through Prometheus and Grafana.',
    tags: ['Docker', 'Microservices', 'Crypto'],
    link: 'https://github.com/LoCh3f/orbital',
  },
  {
    title: 'Poool Game',
    description: 'Concurrent pool-like game developed for PCD, where a human player and a bot compete through physics simulation.',
    tags: ['Java', 'Concurrency', 'Physics'],
    link: 'https://github.com/LoCh3f/assigment-1',
  },
];

const skills = [
  'Assembly (IA-32)',
  'C',
  'Java',
  'Kotlin',
  'SQL',
  'PHP',
  'JavaScript',
  'HTML/CSS',
  'Git',
  'Docker',
  'Verse for Unreal Engine',
];

const socialLinks = [
  { label: 'GitHub', href: 'https://github.com/LoCh3f' },
  { label: 'Email', href: 'mailto:l.c.aldovisconti@gmail.com' },
];

const heroHighlights = [
  { label: 'Current focus', value: 'MSc student' },
  { label: 'Strength', value: 'Adaptability' },
  { label: 'Location', value: 'Italy' },
];

const siteUrl = 'https://loch3f.github.io';
const basePath = '/Aldo';
const canonicalUrl = `${siteUrl}${basePath}/`;
const socialImage = `${siteUrl}${basePath}/assets/aldo.jpg`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Aldo Visconti - Software Engineer & MSc Student. Building reliable software with a practical, product-first mindset." />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content="Aldo Visconti | Software Engineer" />
    <meta property="og:description" content="Software Engineer & MSc Student building reliable software with a practical, product-first mindset." />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:site_name" content="Aldo Visconti" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Aldo Visconti | Software Engineer" />
    <meta name="twitter:description" content="Software Engineer & MSc Student building reliable software with a practical, product-first mindset." />
    <meta name="twitter:image" content={socialImage} />

    <title>Aldo Visconti | Software Engineer</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>

    <Navbar navLinks={navLinks} />

    <div class="page-shell">
      <main id="main-content">
        {/* Hero Section */}
        <Hero
          title="Aldo Visconti"
          tagline="Software Engineer & MSc Student building reliable software with a practical, product-first mindset."
          highlights={heroHighlights}
          ctaPrimary={{ label: 'View Projects', href: '#projects' }}
          ctaSecondary={{ label: 'Email Me', href: 'mailto:l.c.aldovisconti@gmail.com' }}
        />

        <section class="section section-card">
          <div class="container">
            <div class="section-heading">
              <h2>Skills</h2>
            </div>

            <div class="skills-carousel" aria-label="Skills carousel">
              <div class="skills-viewport">
                <div class="skills-track">
                  <div class="skills-list">
                    {skills.map((skill) => (
                      <span class="skill-item">{skill}</span>
                    ))}
                  </div>

                  <div class="skills-list" aria-hidden="true">
                    {skills.map((skill) => (
                      <span class="skill-item">{skill}</span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section id="about" class="section section-card">
          <div class="container">
            <h2>About</h2>
            <p class="prose">
              I graduated in Engineering and Computer Sciences at Alma Mater Studiorum - University of Bologna. I am now pursuing a Master's degree while continuing to turn technical complexity into clean user experiences.
            </p>
            <p class="prose text-muted">
              I am passionate about software development and motivated by curiosity: I like to understand how things work, explore new technologies, and keep improving every day. I enjoy solving problems, learning from real projects, and stepping into new challenges with an open and proactive mindset.
            </p>
          </div>
        </section>

        <section class="section section-card">
          <div class="container">
            <h2>Experience</h2>
            <div class="experience-list">
              <div class="experience-item">
                <p class="text-xs text-faint">Imola, Italy · Mar 2024 - May 2024</p>
                <h3>CP SISTEMI · Software Engineer Intern</h3>
                <p class="text-muted">Ported industrial communication drivers from Java into a new framework for firmware adaptation.</p>
              </div>
              <div class="experience-item">
                <p class="text-xs text-faint">Crotone, Italy · Aug 2020 - Oct 2020</p>
                <h3>RENTBOAT · Front Office Manager</h3>
                <p class="text-muted">Managed check-in/check-out, booking workflows, and fleet maintenance coordination.</p>
              </div>
            </div>
          </div>
        </section>

        <section id="projects" class="section section-card">
          <div class="container">
            <h2>Projects</h2>
            <div class="projects-grid">
              {projects.map((project) => (
                <ProjectCard
                  title={project.title}
                  description={project.description}
                  tags={project.tags}
                  link={project.link}
                />
              ))}
            </div>
          </div>
        </section>

        <section id="contact" class="section section-card">
          <div class="container">
            <h2>Contact</h2>
            <p class="prose text-muted">Open to internship and junior software opportunities.</p>
            <p class="prose">
              Email: <a href="mailto:l.c.aldovisconti@gmail.com">l.c.aldovisconti@gmail.com</a>
            </p>
            <p class="prose">
              GitHub: <a href="https://github.com/LoCh3f" target="_blank" rel="noreferrer noopener">github.com/LoCh3f</a>
            </p>
          </div>
        </section>
      </main>

      <Footer name="Aldo Visconti" social={socialLinks} />
    </div>
  </body>
</html>

<style>
  main {
    flex: 1;
  }

  .section {
    padding-block: var(--spacing-section);
    scroll-margin-top: 6.5rem;
  }

  .section-card {
    margin-top: 1.25rem;
    padding-block: clamp(1.5rem, 2vw + 1rem, 2.5rem);
    border: 1px solid oklch(from var(--color-border) l c h / 0.75);
    border-radius: 1.5rem;
    background: linear-gradient(180deg, oklch(from var(--color-surface) l c h / 0.96), oklch(from var(--color-surface) l c h / 0.88));
    box-shadow: var(--shadow-sm);
  }

  .section-card + .section-card {
    margin-top: 1rem;
  }

  .section h2 {
    margin-bottom: 2rem;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .section-heading h2 {
    margin-bottom: 0;
  }

  .section-heading p {
    margin-bottom: 0;
    max-width: 30rem;
    text-align: right;
  }

  .section p {
    margin-bottom: 1rem;
  }

  .section p:last-child {
    margin-bottom: 0;
  }

  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .experience-item h3 {
    margin-bottom: 0.5rem;
  }

  .experience-item p {
    margin-bottom: 0.5rem;
  }

  .experience-item {
    padding: 1rem 1rem 1rem 1.1rem;
    border-left: 2px solid oklch(from var(--color-primary) l c h / 0.35);
    background-color: oklch(from var(--color-bg) l c h / 0.32);
    border-radius: 0.75rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(320px, 100%), 1fr));
    gap: 1.5rem;
  }

  .skills-list {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.75rem;
  }

  .skill-item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-sm);
    background-color: oklch(from var(--color-surface-offset) l c h / 0.9);
    color: var(--color-text);
    padding: 0.5rem 1rem;
    border: 1px solid oklch(from var(--color-border) l c h / 0.65);
    border-radius: 9999px;
    min-width: max-content;
  }

  .skills-carousel {
    position: relative;
    overflow: hidden;
    border: 1px solid oklch(from var(--color-border) l c h / 0.65);
    border-radius: 1rem;
    background: linear-gradient(90deg, oklch(from var(--color-surface) l c h / 0.92), oklch(from var(--color-surface-offset) l c h / 0.72));
    box-shadow: var(--shadow-sm);
  }

  .skills-viewport {
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
  }

  .skills-track {
    display: flex;
    width: max-content;
    will-change: transform;
    animation: skills-marquee 28s linear infinite;
  }

  .skills-list {
    display: flex;
    gap: 0.75rem;
    width: max-content;
    padding: 0.75rem;
  }

  .skills-carousel:hover .skills-track,
  .skills-carousel:focus-within .skills-track {
    animation-play-state: paused;
  }

  @keyframes skills-marquee {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 640px) {
    .section {
      padding-block: var(--spacing-section);
    }

    .section-card {
      border-radius: 1.125rem;
    }

    .section-heading {
      align-items: start;
      flex-direction: column;
    }

    .section-heading p {
      text-align: left;
    }

    .skills-carousel {
      border-radius: 0.875rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .skills-track {
      animation: none;
      transform: none;
    }
  }
</style>
